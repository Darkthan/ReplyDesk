# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emailauto
DB_USER=emailauto
DB_PASSWORD=changeme

# Sécurité JWT
JWT_SECRET=your-jwt-secret-min-32-characters-long-change-this-in-production

# Clé de chiffrement (64 caractères hexadécimaux - 32 bytes)
# Générer avec: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Email administrateur
ADMIN_EMAIL=admin@example.com

# Mot de passe initial du compte admin (username: admin)
# Générer avec: openssl rand -base64 16
ADMIN_PASSWORD=changeme

# Configuration application
PORT=3000
NODE_ENV=development

# Intervalle de polling pour les emails (en millisecondes)
# 60000 = 1 minute
POLLING_INTERVAL_MS=60000
