{
  "name": "emailauto-server",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "migrate": "node ../scripts/migrate.js",
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "node -e \"const fs=require('fs');const p=require('path');const src=p.join('src','db','migrations');const dst=p.join('dist','db','migrations');fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).filter(f=>f.endsWith('.sql')&&!f.endsWith('.sqlite.sql')).forEach(f=>fs.copyFileSync(p.join(src,f),p.join(dst,f)));\"",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "imapflow": "^1.0.164",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "p-limit": "^3.1.0",
    "pg": "^8.12.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
